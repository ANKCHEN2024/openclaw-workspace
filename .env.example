# ==============================================
# AI 短剧平台 2.0 - 环境变量配置
# ==============================================

# 复制此文件为 .env 并填入实际配置值
# cp .env.example .env

# ==============================================
# 基础配置
# ==============================================
NODE_ENV=production
# 服务器配置
APP_NAME=AI 短剧平台
APP_VERSION=2.0.0

# ==============================================
# 网络配置
# ==============================================
# 后端服务端口
BACKEND_PORT=3000
# 前端服务端口（开发模式）
FRONTEND_PORT=5173
# Nginx 对外端口
HTTP_PORT=80
HTTPS_PORT=443

# ==============================================
# 数据库配置
# ==============================================
# PostgreSQL
POSTGRES_USER=drama_admin
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=drama_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==============================================
# Redis 配置
# ==============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ==============================================
# MinIO 配置
# ==============================================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_this
MINIO_BUCKET_NAME=drama-platform
MINIO_USE_SSL=false

# ==============================================
# JWT 配置
# ==============================================
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# ==============================================
# AI 服务 API Keys
# ==============================================
# 阿里通义千问 (LLM)
TONGYI_API_KEY=your_tongyi_api_key
# 阿里通义万相 (Image)
TONGYI_WANXIANG_API_KEY=
# 快手可灵 AI (Video)
KELING_API_KEY=your_keling_api_key
# 火山即梦 AI (Video)
JIMENG_API_KEY=your_jimeng_api_key
# 阿里云智能语音 (TTS/ASR)
ALIYUN_VOICE_API_KEY=your_aliyun_voice_api_key
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
# 网易云音乐 (BGM)
NETEASE_MUSIC_API_KEY=your_netease_music_api_key

# ==============================================
# 日志配置
# ==============================================
LOG_LEVEL=info
LOG_DIR=/app/logs
LOG_FILE=${LOG_DIR}/app.log

# ==============================================
# 文件上传配置
# ==============================================
MAX_FILE_SIZE=104857600
UPLOAD_DIR=/app/uploads

# ==============================================
# 前端配置
# ==============================================
VITE_API_BASE_URL=http://localhost/api/v1
VITE_WS_URL=ws://localhost/ws

# ==============================================
# Docker 配置
# ==============================================
# 数据卷路径（可选，用于持久化数据）
DATA_DIR=./data
POSTGRES_DATA_DIR=${DATA_DIR}/postgres
REDIS_DATA_DIR=${DATA_DIR}/redis
MINIO_DATA_DIR=${DATA_DIR}/minio
UPLOADS_DATA_DIR=${DATA_DIR}/uploads
