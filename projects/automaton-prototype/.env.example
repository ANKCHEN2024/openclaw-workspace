# Automaton Agent 配置文件

# Agent 配置
AGENT_NAME=MyAutomaton
INITIAL_BALANCE=1000
TICK_INTERVAL_MS=5000

# 生存阈值
LOW_COMPUTE_THRESHOLD=500
CRITICAL_THRESHOLD=100
DEAD_THRESHOLD=0

# 成本配置
THOUGHT_COST=1
ACTION_COST=5
OBSERVATION_COST=2
API_CALL_COST=10
FILE_OPERATION_COST=3

# 数据库配置
DB_PATH=./data/agent_state.db

# 日志配置
LOG_LEVEL=info
