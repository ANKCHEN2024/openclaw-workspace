# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_drama_platform?schema=public"

# Redis (for job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# DashScope API (阿里百炼大模型)
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_VIDEO_ENDPOINT=https://dashscope.aliyuncs.com/api/v1

# Video Storage
VIDEO_STORAGE_PATH=/path/to/storage/videos

# Queue Configuration
VIDEO_QUEUE_CONCURRENCY=3

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development
