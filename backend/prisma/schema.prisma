generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt    @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @db.VarChar(255)
  avatarUrl    String?   @db.VarChar(500)
  phone        String?   @db.VarChar(20)
  isActive     Boolean   @default(true)
  role         String    @default("user") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @default(now()) @db.Timestamp(6)
  projects     Project[]
  tasks        Task[]

  @@index([email])
  @@index([username])
}

model Project {
  id              BigInt        @id @default(autoincrement())
  userId          BigInt
  name            String        @db.VarChar(200)
  description     String?
  novelText       String?
  episodeCount    Int           @default(10)
  episodeDuration Int           @default(60)
  videoRatio      String        @default("9:16") @db.VarChar(10)
  videoQuality    String        @default("1080p") @db.VarChar(20)
  status          ProjectStatus @default(draft)
  settings        Json?
  archivedAt      DateTime?     @db.Timestamp(6)
  createdAt       DateTime      @default(now()) @db.Timestamp(6)
  updatedAt       DateTime      @default(now()) @db.Timestamp(6)
  characters      Character[]
  episodes        Episode[]
  EpisodeV2       EpisodeV2[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes          Scene[]
  scripts         Script[]
  seasons         Season[]
  tasks           Task[]

  @@index([userId])
  @@index([status])
  @@index([archivedAt])
  @@index([createdAt])
}

model Episode {
  id            BigInt        @id @default(autoincrement())
  projectId     BigInt
  episodeNumber Int
  title         String?       @db.VarChar(200)
  summary       String?
  script        String?
  status        EpisodeStatus @default(draft)
  duration      Int?
  createdAt     DateTime      @default(now()) @db.Timestamp(6)
  updatedAt     DateTime      @default(now()) @db.Timestamp(6)
  audios        Audio[]
  bgms          Bgm[]
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storyboards   Storyboard[]
  videos        Video[]

  @@unique([projectId, episodeNumber])
  @@index([projectId])
  @@index([status])
}

model Character {
  id               BigInt            @id @default(autoincrement())
  projectId        BigInt
  name             String            @db.VarChar(100)
  description      String?
  appearance       String?
  gender           String?           @db.VarChar(10)
  ageRange         String?           @db.VarChar(20)
  personality      Json?
  status           CharacterStatus   @default(active)
  createdAt        DateTime          @default(now()) @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @db.Timestamp(6)
  audios           Audio[]
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characterImages  CharacterImage[]
  scriptCharacters ScriptCharacter[]

  @@index([projectId])
  @@index([status])
}

model CharacterImage {
  id               BigInt    @id @default(autoincrement())
  characterId      BigInt
  imageUrl         String    @db.VarChar(500)
  imageType        String?   @db.VarChar(50)
  prompt           String?
  generationParams Json?
  createdAt        DateTime  @default(now()) @db.Timestamp(6)
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
}

model Scene {
  id           BigInt       @id @default(autoincrement())
  projectId    BigInt
  name         String       @db.VarChar(100)
  description  String?
  locationType String?      @db.VarChar(50)
  timeOfDay    String?      @db.VarChar(20)
  atmosphere   String?      @db.VarChar(50)
  visualStyle  String?
  status       SceneStatus  @default(active)
  createdAt    DateTime     @default(now()) @db.Timestamp(6)
  updatedAt    DateTime     @default(now()) @db.Timestamp(6)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sceneImages  SceneImage[]

  @@index([projectId])
}

model SceneImage {
  id               BigInt   @id @default(autoincrement())
  sceneId          BigInt
  imageUrl         String   @db.VarChar(500)
  imageType        String?  @db.VarChar(50)
  prompt           String?
  generationParams Json?
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  scene            Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([sceneId])
}

model Storyboard {
  id                BigInt           @id @default(autoincrement())
  episodeId         BigInt
  shotNumber        Int
  description       String?
  visualDescription String?
  shotType          String?          @db.VarChar(50)
  cameraAngle       String?          @db.VarChar(50)
  cameraMovement    String?          @db.VarChar(50)
  duration          Int?
  dialogue          String?
  action            String?
  status            StoryboardStatus @default(draft)
  createdAt         DateTime         @default(now()) @db.Timestamp(6)
  updatedAt         DateTime         @default(now()) @db.Timestamp(6)
  episode           Episode          @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  videoClips        VideoClip[]

  @@unique([episodeId, shotNumber])
  @@index([episodeId])
}

model VideoClip {
  id               BigInt          @id @default(autoincrement())
  storyboardId     BigInt
  videoId          BigInt?
  videoUrl         String          @db.VarChar(500)
  sourceType       String?         @db.VarChar(50)
  aiProvider       String?         @db.VarChar(50)
  generationParams Json?
  duration         Int?
  status           VideoClipStatus @default(pending)
  createdAt        DateTime        @default(now()) @db.Timestamp(6)
  storyboard       Storyboard      @relation(fields: [storyboardId], references: [id], onDelete: Cascade)
  video            Video?          @relation(fields: [videoId], references: [id])

  @@index([storyboardId])
  @@index([videoId])
  @@index([status])
}

model Audio {
  id              BigInt      @id @default(autoincrement())
  episodeId       BigInt
  characterId     BigInt?
  audioUrl        String      @db.VarChar(500)
  audioType       String?     @db.VarChar(50)
  textContent     String?
  voiceId         String?     @db.VarChar(50)
  synthesisParams Json?
  duration        Int?
  status          AudioStatus @default(pending)
  createdAt       DateTime    @default(now()) @db.Timestamp(6)
  character       Character?  @relation(fields: [characterId], references: [id])
  episode         Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([characterId])
}

model Bgm {
  id         BigInt   @id @default(autoincrement())
  episodeId  BigInt
  audioUrl   String   @db.VarChar(500)
  musicStyle String?  @db.VarChar(50)
  mood       String?  @db.VarChar(50)
  duration   Int?
  metadata   Json?
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  episode    Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
}

model Video {
  id                BigInt      @id @default(autoincrement())
  episodeId         BigInt
  videoUrl          String      @db.VarChar(500)
  resolution        String?     @db.VarChar(20)
  format            String?     @db.VarChar(20)
  duration          Int?
  fileSize          BigInt?
  status            VideoStatus @default(pending)
  compositionParams Json?
  createdAt         DateTime    @default(now()) @db.Timestamp(6)
  updatedAt         DateTime    @default(now()) @db.Timestamp(6)
  episode           Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  videoClips        VideoClip[]

  @@index([episodeId])
  @@index([status])
}

model Task {
  id          BigInt     @id @default(autoincrement())
  userId      BigInt
  projectId   BigInt?
  taskType    TaskType
  status      TaskStatus @default(pending)
  progress    Int        @default(0)
  message     String?
  metadata    Json?
  createdAt   DateTime   @default(now()) @db.Timestamp(6)
  updatedAt   DateTime   @default(now()) @db.Timestamp(6)
  completedAt DateTime?  @db.Timestamp(6)
  project     Project?   @relation(fields: [projectId], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model Season {
  id          BigInt      @id @default(autoincrement())
  projectId   BigInt
  number      Int
  title       String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  episodes    EpisodeV2[]
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
}

model EpisodeV2 {
  id          BigInt    @id @default(autoincrement())
  projectId   BigInt
  seasonId    BigInt?
  number      Int
  title       String
  description String?
  status      String    @default("draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id])
  season      Season?   @relation(fields: [seasonId], references: [id])
  scenes      SceneV2[]

  @@unique([projectId, number])
  @@index([projectId])
  @@index([seasonId])
  @@index([status])
}

model SceneV2 {
  id               BigInt            @id @default(autoincrement())
  episodeId        BigInt
  number           Int
  location         String
  timeOfDay        String
  content          String
  dialogue         String?
  duration         Int?
  status           String            @default("draft")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  episode          EpisodeV2         @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  videoGenerations VideoGeneration[]

  @@unique([episodeId, number])
  @@index([episodeId])
  @@index([status])
}

model VideoGeneration {
  id             String    @id @default(uuid())
  sceneId        BigInt
  status         String    @default("pending")
  progress       Int       @default(0)
  videoUrl       String?   @db.VarChar(500)
  thumbnailUrl   String?   @db.VarChar(500)
  duration       Int?
  errorMessage   String?
  config         Json?
  externalTaskId String?   @db.VarChar(100)
  provider       String?   @db.VarChar(50)
  startedAt      DateTime? @db.Timestamp(6)
  completedAt    DateTime? @db.Timestamp(6)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt
  scene          SceneV2   @relation(fields: [sceneId], references: [id])

  @@index([sceneId])
  @@index([status])
  @@index([createdAt])
}

model VideoTemplate {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  category    String   @db.VarChar(50)
  duration    Int
  thumbnail   String?  @db.VarChar(500)
  config      Json
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model Script {
  id          BigInt            @id @default(autoincrement())
  projectId   BigInt
  title       String            @db.VarChar(200)
  description String?
  content     String
  version     Int               @default(1)
  status      ScriptStatus      @default(draft)
  createdAt   DateTime          @default(now()) @db.Timestamp(6)
  updatedAt   DateTime          @default(now()) @db.Timestamp(6)
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characters  ScriptCharacter[]
  versions    ScriptVersion[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model ScriptVersion {
  id        BigInt   @id @default(autoincrement())
  scriptId  BigInt
  version   Int
  content   String
  changeLog String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, version])
  @@index([scriptId])
}

model ScriptCharacter {
  scriptId    BigInt
  characterId BigInt
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  script      Script    @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@id([scriptId, characterId])
  @@index([scriptId])
  @@index([characterId])
}

enum ProjectStatus {
  draft
  analyzing
  character_building
  scene_building
  generating
  completed
  failed
}

enum EpisodeStatus {
  draft
  storyboard_ready
  video_generating
  audio_generating
  composing
  completed
  failed
}

enum TaskStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum TaskType {
  story_analyze
  character_generate
  scene_generate
  storyboard_generate
  video_generate
  audio_synthesize
  bgm_generate
  video_compose
}

enum CharacterStatus {
  active
  inactive
}

enum SceneStatus {
  active
  inactive
}

enum StoryboardStatus {
  draft
  ready
  generating
  completed
  failed
}

enum VideoClipStatus {
  pending
  generating
  completed
  failed
}

enum AudioStatus {
  pending
  synthesizing
  completed
  failed
}

enum VideoStatus {
  pending
  composing
  completed
  failed
}

enum ScriptStatus {
  draft
  published
  archived
}
