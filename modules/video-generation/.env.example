# 环境变量配置示例
# 复制为 .env 并填入实际值

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO 配置
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=video-generation

# 快手可灵 AI 配置
KELING_API_KEY=your_keling_api_key
KELING_API_SECRET=your_keling_api_secret
KELING_BASE_URL=https://api.kuaishou.com/kl

# 火山引擎即梦 AI 配置
JIMENG_API_KEY=your_jimeng_api_key
JIMENG_API_SECRET=your_jimeng_api_secret
JIMENG_BASE_URL=https://api.volcengine.com/jimeng

# 队列配置
MAX_CONCURRENT_TASKS=5

# 日志配置
LOG_LEVEL=info
