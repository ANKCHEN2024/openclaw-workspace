# 环境变量配置示例

# 阿里云 DashScope API 配置
ALIYUN_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret_here

# 通义万相 API 端点（可选，默认使用官方端点）
ALIYUN_ENDPOINT=https://dashscope.aliyuncs.com

# MinIO 对象存储配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-drama-storyboards
MINIO_USE_SSL=false

# 数据库配置（PostgreSQL）
DATABASE_URL=postgresql://user:password@localhost:5432/ai_drama_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_CONNECTIONS=20

# Redis 配置（用于任务队列和缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 服务配置
PORT=3000
NODE_ENV=development

# 分镜生成配置
STORYBOARD_DEFAULT_COUNT_PER_ANGLE=4
STORYBOARD_CONSISTENCY_THRESHOLD=85
STORYBOARD_DEFAULT_QUALITY=high
STORYBOARD_DEFAULT_ASPECT_RATIO=16:9

# CLIP 模型配置（用于一致性计算，可选）
CLIP_MODEL_PATH=./models/clip-vit-base-patch32
USE_CLIP_MODEL=false

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
