# API 提供商配置示例

# ===========================================
# 环境变量配置
# 将这些配置添加到你的 .env 文件中
# ===========================================

# Runway ML API 密钥
# 获取地址：https://runwayml.com/api-keys
RUNWAY_API_KEY=your_runway_api_key_here

# Pika Labs API 密钥
# 获取地址：https://pika.art/api
PIKA_API_KEY=your_pika_api_key_here

# Kling AI（可灵）API 密钥
# 获取地址：https://platform.klingai.com/
KLING_API_KEY=your_kling_api_key_here

# Stable Video Diffusion（本地部署，可选）
# 如果使用本地部署，可以不设置或设置自定义密钥
SVD_API_KEY=optional_local_api_key

# SVD 输出目录（可选，默认：./output/svd）
SVD_OUTPUT_DIR=./output/svd

# ===========================================
# 提供商配置说明
# ===========================================

## Runway ML
# - 专业级 AI 视频生成
# - 支持 Gen-2 模型
# - 适合高质量视频制作
# - 价格：按积分计费

## Pika Labs
# - 快速视频生成
# - 支持多种风格
# - 适合社交媒体内容
# - 价格：订阅制

## Kling AI（可灵）
# - 快手推出的 AI 模型
# - 支持中文提示词
# - 视频质量优秀
# - 价格：按量计费

## Stable Video Diffusion
# - 开源模型，本地部署
# - 无 API 费用
# - 需要 GPU 支持
# - 适合批量生成

# ===========================================
# 使用示例
# ===========================================

